# ============================================================
# Soligo Air — Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to git
# ============================================================

# ----- GoHighLevel CRM -----
GHL_API_KEY=your_ghl_api_key_here
GHL_LOCATION_ID=your_ghl_location_id_here
GHL_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/YOUR_WEBHOOK_ID

# ----- Resend Email API -----
RESEND_API_KEY=re_your_api_key_here
FROM_EMAIL=leads@soligoair.shop
NOTIFY_EMAIL=info@soligoair.com

# ----- Meta Conversions API -----
META_PIXEL_ID=your_meta_pixel_id
META_CAPI_TOKEN=your_meta_capi_access_token

